                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?width=160&height=160/" alt="avatar" class="w-9 rounded-full">
                    <span class="font-semibold text-lg text-gray-200"><%= user.username %></span>
