<nav class="bg-[#4618d0] flex justify-between items-center p-2 w-full z-10">
    <div class="order-1">
        <div class="flex flex-row space-x-3 items-center">
            <img src="https://dbl-static.usercontent.prism.gg/embed/avatars/4.png" alt="boubouw" class="rounded-full w-9">
            <a href="https://github.com/BouBouw/DiscordBot-Template-V14/tree/main" class="font-bold text-xl text-white">
                Template
            </a>
        </div>
    </div>
    <div class="order-2">
        <ul class="flex flex-row space-x-10 items-center">
            <li>
                <a href="/home" class="text-white text-sm uppercase hover:underline underline-offset-2">
                    Home
                </a>
            </li>
            <li>
                <a href="/documentation" class="text-white text-sm uppercase hover:underline underline-offset-2">
                    Documentation
                </a>
            </li>
            <li>
                <a href="/contact" class="text-white text-sm uppercase hover:underline underline-offset-2">
                    Contact
                </a>
            </li>
        </ul>
